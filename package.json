{
  "name": "used-lab-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,css \"next dev\" \"npm run watch:css\"",
    "dev:next": "next dev",
    "watch:css": "chokidar \"app/style.css\" \"app/search.css\" \"app/sp-overrides.css\" -c \"npm run build:css && node scripts/hash-assets.mjs\" --initial",
    "build:css": "cat app/style.css app/search.css app/sp-overrides.css | csso --output public/css/non-critical.min.css",
    "build:assets": "npm run build:css && node scripts/hash-assets.mjs",
    "build:checks:sitemap": "node --import tsx scripts/check-sitemap-coverage.ts",
    "build:checks:lint": "eslint --max-warnings 0",
    "build:checks": "npm run build:checks:sitemap && npm run build:checks:lint",
    "build": "npm run build:assets && npm run build:checks && next build",
    "start": "next start",
    "lint": "eslint",
    "verify:required": "npm run build:checks:sitemap",
    "verify:price-info": "node --import tsx scripts/check-price-info.ts",
    "verify:seo": "npm run check-links:internal",
    "verify:full": "npm run verify:required && npm run verify:price-info && npm run verify:seo",
    "verify": "npm run verify:full",
    "fetch-prices": "tsx scripts/fetch-prices.ts",
    "fetch-prices:iphone": "tsx scripts/fetch-prices.ts iphone",
    "fetch-prices:ipad": "tsx scripts/fetch-prices.ts ipad",
    "fetch-prices:watch": "tsx scripts/fetch-prices.ts watch",
    "fetch-prices:airpods": "tsx scripts/fetch-prices.ts airpods",
    "check-links": "tsx scripts/check-links.ts",
    "check-links:local": "tsx scripts/check-links.ts --local",
    "check-links:internal": "tsx scripts/check-links.ts --internal-only"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3"
  },
  "browserslist": [
    "chrome >= 109",
    "edge >= 109",
    "firefox >= 115",
    "safari >= 16",
    "ios_saf >= 16",
    "samsung >= 20",
    "not dead"
  ],
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "csso-cli": "^4.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "linkinator": "^7.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
