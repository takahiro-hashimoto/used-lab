NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=
ADMIN_SESSION_TOKEN=

# POST /api/revalidate-all の保護用シークレット。
# Vercelデプロイ後に外部CIなどからキャッシュ再検証を叩く場合に使います。
REVALIDATE_SECRET=

# Amazon Creators API（PA-APIの後継）— Amazon整備済み(Renewed)取得用。
# アソシエイト/Creators管理画面で発行。VERSION は資格情報のバージョン（例: 3.3）。
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_VERSION=
AMAZON_CREATORS_PARTNER_TAG=
