{
  "name": "used-lab-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:css": "cat app/style.css app/author-byline.css app/search.css app/sp-overrides.css | csso --output public/css/non-critical.min.css",
    "build": "npm run build:css && tsx scripts/check-sitemap-coverage.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "fetch-prices": "tsx scripts/fetch-prices.ts",
    "fetch-prices:iphone": "tsx scripts/fetch-prices.ts iphone",
    "fetch-prices:ipad": "tsx scripts/fetch-prices.ts ipad",
    "fetch-prices:watch": "tsx scripts/fetch-prices.ts watch",
    "fetch-prices:airpods": "tsx scripts/fetch-prices.ts airpods"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3"
  },
  "browserslist": [
    "chrome >= 109",
    "edge >= 109",
    "firefox >= 115",
    "safari >= 16",
    "ios_saf >= 16",
    "samsung >= 20",
    "not dead"
  ],
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csso-cli": "^4.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
